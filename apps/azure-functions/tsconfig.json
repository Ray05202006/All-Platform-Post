{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "rootDir": "..",
    "skipLibCheck": true,
    "paths": {
      "@all-platform-post/shared": ["../../packages/shared/src"],
      "@all-platform-post/text-splitter": ["../../packages/text-splitter/src"]
    }
  },
  "include": ["src/**/*.ts", "../api/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "../api/src/**/*.spec.ts"]
}
