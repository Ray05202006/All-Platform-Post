{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "ignorePatterns": ["src/generated/**"],
  "rules": {
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_",
      "destructuredArrayIgnorePattern": "^_"
    }]
  }
}
