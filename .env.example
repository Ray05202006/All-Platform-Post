# Database
DATABASE_URL="postgresql://user:password@localhost:5432/allplatformpost?schema=public"

# Encryption (Generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your-64-char-hex-key-here"

# JWT Secret (Generate with: openssl rand -hex 32)
JWT_SECRET="your-jwt-secret-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# Azure Functions backend URL (used by frontend to call the API)
NEXT_PUBLIC_API_URL="http://localhost:7071"

# GitHub Pages deployment (set basePath when deploying under a subdirectory)
# For GitHub Pages: NEXT_PUBLIC_BASE_PATH=/All-Platform-Post
# Leave empty for local development
NEXT_PUBLIC_BASE_PATH=""

# Azure Functions CORS (backend env var — scheme+host only, no path)
# For production: CORS_ORIGIN=https://YOUR_GITHUB_USERNAME.github.io
CORS_ORIGIN="http://localhost:3000"

# Facebook App
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook App
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# Instagram (uses Facebook App)
# Instagram Business accounts are connected through Facebook

# Twitter/X App (OAuth 2.0)
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"

# Twitter/X App (OAuth 1.0a - for user-scoped posting)
# Only app-level credentials belong in env. Per-user access tokens must be
# obtained via the OAuth 1.0a flow and stored securely (e.g., in your database),
# not as global environment variables.
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"

# Threads (uses Facebook App)
# Threads uses the same Facebook App credentials

# Cleanup Configuration (Optional)
# CLEANUP_POSTS_RETENTION_DAYS=90
# CLEANUP_LOGS_RETENTION_DAYS=30
# CLEANUP_FAILED_JOBS_RETENTION_HOURS=24
